{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Role",
    "type": "object",
    "properties": {
        "alias": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "permissions": {
            "type": "array",
            "default": [],
            "items": {
                "type": "string"
            }
        },
        "ownerId": {
            "type": "integer"
        }
    },
    "required": ["alias", "name", "description", "permissions"]
}
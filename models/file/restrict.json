{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RestrictFileBody",
  "description": "Restrict or unrestrict a datafile.",
  "type": "object",
  "properties": {
    "restrict": {
      "type": "boolean",
      "description": "Whether to restrict access to the file"
    },
    "enableAccessRequest": {
      "type": "boolean",
      "description": "Whether to enable access requests for the restricted file"
    },
    "termsOfAccess": {
      "type": "string",
      "description": "Reason or terms for the restricted access"
    }
  },
  "required": ["restrict"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "restrict": { "const": true },
          "enableAccessRequest": { "const": false }
        },
        "required": ["restrict", "enableAccessRequest"]
      },
      "then": {
        "required": ["restrict", "termsOfAccess"]
      }
    }
  ]
}
